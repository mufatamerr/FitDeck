# ═══════════════════════════════════════════════════════════════════
# FitDeck — Environment template
#
# 1. Copy this file to `.env` in the repo root (Flask reads it from there).
# 2. Copy the VITE_* block to `frontend/.env.local` (Vite does not read root .env
#    for client secrets; only variables prefixed with VITE_ are sent to the browser).
# ═══════════════════════════════════════════════════════════════════

# ── Auth0 (SPA + API + optional M2M for admin) ──────────────────────

# Backend API URL (frontend)
VITE_API_URL=http://127.0.0.1:5000

# ── Google Cloud Vision ─────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=

# ── Google AI Studio (Gemma + Nano Banana / Gemini image) ───────────
GOOGLE_AI_STUDIO_API_KEY=

# ── ElevenLabs ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── OpenWeatherMap (activate early; can take up to 2 hours) ──────────
OPENWEATHER_API_KEY=

# ── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── remove.bg (optional) ────────────────────────────────────────────
REMOVEBG_API_KEY=

# ── Fashn.ai ─────────────────────────────────────────────────────────
FASHN_API_KEY=

# ── App ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///fitdeck.db
FLASK_SECRET_KEY=4cf001326a0b3677165a491f7111fd2722adcf27de21845b8fda4b51deb16b8d
FRONTEND_URL=http://localhost:5173
