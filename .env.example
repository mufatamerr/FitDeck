# ═══════════════════════════════════════════════════════════════════
# FitDeck — Environment template
#
# 1. Copy this file to `.env` in the repo root (Flask reads it from there).
# 2. Copy the VITE_* block to `frontend/.env.local` (Vite does not read root .env
#    for client secrets; only variables prefixed with VITE_ are sent to the browser).
# ═══════════════════════════════════════════════════════════════════

# ── Auth0 (SPA + API + optional M2M for admin) ──────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=https://fitdeck-api
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=

# Used by Vite frontend (must be prefixed VITE_)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://fitdeck-api

# Backend API URL (frontend)
VITE_API_URL=http://127.0.0.1:5000

# ── Google Cloud Vision ─────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=

# ── Google AI Studio (Gemma + Nano Banana / Gemini image) ───────────
GOOGLE_AI_STUDIO_API_KEY=

# ── ElevenLabs ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── OpenWeatherMap (activate early; can take up to 2 hours) ──────────
OPENWEATHER_API_KEY=

# ── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── remove.bg (optional) ────────────────────────────────────────────
REMOVEBG_API_KEY=

# ── Fashn.ai ─────────────────────────────────────────────────────────
FASHN_API_KEY=

# ── App ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///fitdeck.db
FLASK_SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173
