# ═══════════════════════════════════════════════════════════════════
# FitDeck — Environment template
#
# 1. Copy to `fitdeck/.env` (Flask loads it via backend/run.py).
# 2. Copy only VITE_* lines to `frontend/.env.local` (never put secrets there).
# ═══════════════════════════════════════════════════════════════════

# ── Auth0 ───────────────────────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_AUDIENCE=https://fitdeck-api
AUTH0_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=

# Frontend (also in frontend/.env.local)
VITE_API_URL=http://127.0.0.1:5001
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://fitdeck-api

# ── Google Cloud Vision (wardrobe + admin catalog tagging) ──────────
GOOGLE_CLOUD_VISION_API_KEY=

# ── Google AI Studio — FitBot + future image tools (same key) ───────
GOOGLE_AI_STUDIO_API_KEY=

# ── FitBot (Generative Language API + OpenWeather + ElevenLabs) ───────
# Default OpenWeather `q` when the client does not send `location`.
FITBOT_DEFAULT_LOCATION=Mississauga,CA
# If the client omits `include_weather`, this default is used (true/false).
FITBOT_INCLUDE_WEATHER=true
# Model id for https://generativelanguage.googleapis.com/.../models/MODEL:generateContent
# Default gemini-2.0-flash works with most AI Studio keys. gemma-2-2b-it often returns 404 (retired).
# List names for your key: curl -s "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY" | head
FITBOT_GEMMA_MODEL=gemini-2.0-flash
# Optional: extra system instructions (one paragraph; keep short).
# FITBOT_EXTRA_INSTRUCTIONS=Prefer Canadian retailers when suggesting buys.

# ElevenLabs — FitBot TTS (POST /fitbot/speak)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional TTS overrides
# FITBOT_ELEVENLABS_MODEL=eleven_monolingual_v1
# FITBOT_VOICE_STABILITY=0.5
# FITBOT_VOICE_SIMILARITY=0.75

# OpenWeatherMap — current + 5-day forecast for FitBot (key can take ~2h to activate)
OPENWEATHER_API_KEY=

# ── Cloudinary ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── remove.bg (optional) ───────────────────────────────────────────
REMOVEBG_API_KEY=

# ── Fashn.ai (optional — try-on results) ─────────────────────────────
FASHN_API_KEY=

# ── App ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///fitdeck.db
FLASK_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:5173
