# Copy to frontend/.env.local — only VITE_* vars are exposed to the browser.

VITE_API_URL=http://127.0.0.1:5001

VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://fitdeck-api

# FitBot keys (Gemma, ElevenLabs, OpenWeather) live in the repo root `.env`
# on the Flask server — not here.
